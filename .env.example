# Server
PORT=3000

# Mongo
MONGODB_URI=mongodb://localhost:27017/email-to-task-crm

# Redis (Bull queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Inbound email webhook
# Shared secret the fake email-provider signs its payloads with (HMAC-SHA256
# over the raw request body, sent as the X-Webhook-Signature header).
EMAIL_WEBHOOK_SECRET=change-me-webhook-secret

# LLM classification
# "anthropic" calls the real Claude API (requires ANTHROPIC_API_KEY).
# "mock" uses a deterministic keyword-based classifier, no network/API key needed.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
